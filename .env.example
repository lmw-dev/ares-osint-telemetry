# Ares Vault root path (required)
ARES_VAULT_PATH="/path/to/your/Ares-Matrix-DB"

# -------------------------
# Optional LLM backfill config for osint_postmatch.py
# -------------------------
ARES_USE_LLM_BACKFILL=0

# Provider: openai | gemini
ARES_LLM_PROVIDER=openai

# Unified API key (optional, highest priority)
ARES_LLM_API_KEY=

# Provider-specific keys (used when ARES_LLM_API_KEY is empty)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional custom gateway base URL
# If empty, falls back to official endpoint by provider.
# OpenAI: https://api.openai.com/v1
# Gemini: https://generativelanguage.googleapis.com/v1beta
ARES_LLM_BASE_URL=

# Optional model (provider-specific default will be used when empty)
# openai default: gpt-4o-mini
# gemini default: gemini-1.5-flash
ARES_LLM_MODEL=

# Optional runtime controls
ARES_LLM_TIMEOUT_SEC=20
ARES_LLM_MIN_CONFIDENCE=0.6
ARES_LLM_MAX_ENTROPY_DELTA=0.05
